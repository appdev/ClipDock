{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clipdock.local/mobile-v4/web-bridge.schema.json",
  "title": "ClipDock Mobile V4 Web Bridge",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "requestId", "action"],
  "properties": {
    "version": { "const": 1 },
    "requestId": { "type": "string", "minLength": 1, "maxLength": 80 },
    "action": {
      "type": "string",
      "enum": [
        "selectDestination",
        "openItemDetail",
        "closeDetail",
        "showRemoteRetrieval",
        "hideRemoteRetrieval",
        "showDeleteConfirm",
        "hideDeleteConfirm",
        "copyItem",
        "downloadAndCopy",
        "downloadToCache",
        "copyThumbnail",
        "removeLocalCache",
        "deleteSyncRecord",
        "syncNow",
        "setP2pEnabled",
        "setWifiOnly",
        "setOverlayEnabled",
        "setOverlaySize",
        "setOverlayOpacity",
        "setOverlayVerticalFraction",
        "setOverlaySnapEdge",
        "openSettingsDetail",
        "closeSettingsDetail"
      ]
    },
    "stableId": { "type": "string", "minLength": 1, "maxLength": 96 },
    "route": { "type": "string", "enum": ["history", "devices", "files", "settings", "keep_alive", "floating_ball", "item_detail_text", "remote_asset_sheet", "delete_confirm"] },
    "sheet": { "type": "string", "enum": ["remote_retrieval", "delete_confirm"] },
    "setting": { "type": "string", "enum": ["p2p_enabled", "wifi_only", "overlay_enabled", "overlay_size", "overlay_opacity", "overlay_vertical_fraction", "overlay_snap_edge"] },
    "value": {
      "oneOf": [
        { "type": "boolean" },
        { "type": "number" },
        { "type": "string", "maxLength": 32 },
        { "type": "null" }
      ]
    }
  },
  "forbiddenNativePayloadFields": [
    "token",
    "deviceToken",
    "serverUrl",
    "url",
    "uri",
    "file",
    "path",
    "payload",
    "payloadBytes",
    "item",
    "items",
    "repository"
  ]
}
